{
  "manifest_version": 3,
  "name": "知乎软广过滤器",
  "version": "1.0.0",
  "description": "自动识别并隐藏知乎 Feed 中的软文广告",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.zhihu.com/*",
    "https://open.bigmodel.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhihu.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "知乎软广过滤器",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
